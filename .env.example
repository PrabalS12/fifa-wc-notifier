# Copy to .env for local runs:  cp .env.example .env  (then `set -a; source .env; set +a`)
# In GitHub, add each of these as a repository secret instead.

# --- Football data (football-data.org -> free API key) ---
FOOTBALL_DATA_API_KEY=

# --- Gemini (Google AI Studio -> API key) ---
GEMINI_API_KEY=
# Optional; defaults to gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# --- WhatsApp Cloud API (Meta for Developers) ---
WHATSAPP_TOKEN=                 # permanent System User token (NOT the 24h temp token)
WHATSAPP_PHONE_NUMBER_ID=       # the test number's Phone Number ID
WHATSAPP_RECIPIENT=             # your number incl. country code, e.g. 9198XXXXXXXX
WHATSAPP_TEMPLATE_NAME=wc_update
WHATSAPP_TEMPLATE_LANG=en_US
# Set to false ONLY for local testing inside an open 24h window (sends free-form text).
WHATSAPP_USE_TEMPLATE=true

# --- Optional: direct YouTube highlight links (leave blank to use search URLs) ---
YOUTUBE_API_KEY=
